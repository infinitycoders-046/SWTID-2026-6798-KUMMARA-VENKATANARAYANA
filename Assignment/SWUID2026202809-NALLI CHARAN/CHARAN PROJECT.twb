        <calculation class='tableau' formula='IF [healthy_feeling]&gt;=8 THEN&quot;Highly healthy&quot;&#13;&#10;ELSEIF[healthy_feeling]&gt;=5 THEN&quot;Moderately Healthy&quot;&#13;&#10;ELSE&quot;less healthy&quot;&#13;&#10;END' />
